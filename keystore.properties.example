# Шаблон конфигурации подписи релиза. Скопируй в keystore.properties (он в .gitignore)
# и подставь реальные значения. Сам keystore.properties и .jks НЕ коммитятся.
#
# ВАЖНО: забэкапь remindy-release.jks И этот пароль вне репозитория (облако/менеджер
# паролей). Потеря ключа = невозможность выпускать обновления с тем же applicationId.
storeFile=remindy-release.jks
storePassword=ЗАМЕНИ_МЕНЯ
keyAlias=remindy
keyPassword=ЗАМЕНИ_МЕНЯ
