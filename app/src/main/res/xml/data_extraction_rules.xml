<?xml version="1.0" encoding="utf-8"?>
<!--
    Конфиденциальность: данные приложения (карта расположения вещей) не покидают
    устройство. Исключаем всё и из облачного бэкапа, и из переноса телефон-телефон
    (D2D на Android 12+). На Android <=11 бэкап дополнительно выключен через
    android:allowBackup="false" в манифесте.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="file" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
