<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Замок чтения (этап 5). НЕТ INTERNET – приложение полностью офлайн. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <uses-feature
        android:name="android.hardware.microphone"
        android:required="true" />

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:theme="@style/Theme.Remindy">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".record.ConfirmationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".list.ListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".search.SearchActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale"
            android:windowSoftInputMode="adjustResize" />

        <!-- Замок чтения: configChanges, чтобы поворот не пересоздавал экран и не перезапускал биометрию -->
        <activity
            android:name=".security.UnlockActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale" />

        <!-- Настройки замка (Фаза 4, ТЗ F4). Сами под гейтом. -->
        <activity
            android:name=".security.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale" />

        <!-- Онбординг: автопоказ на первом запуске + «Как пользоваться» из настроек -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|smallestScreenSize|keyboardHidden|uiMode|navigation|fontScale" />

    </application>

</manifest>
